{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capability for the desktop windows",
  "windows": ["menu", "workspace"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-focusable",
    "shell:allow-open",
    "core:tray:default",
    "os:default",
    "store:default"
  ]
}
