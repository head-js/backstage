{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop",
  "version": "0.1.0",
  "identifier": "com.lisitede.backstage.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "menu",
        "url": "menu.html",
        "title": "desktop menu",
        "width": 208,
        "height": 600,
        "x": 1072,
        "y": 80,
        "minWidth": 208,
        "minHeight": 600,
        "resizable": false,
        "fullscreen": false,
        "alwaysOnTop": true,
        "decorations": true,
        "transparent": true,
        "skipTaskbar": false
      },
      {
        "label": "workspace",
        "url": "workspace.html",
        "title": "desktop",
        "width": 992,
        "height": 600,
        "x": 80,
        "y": 80,
        "minWidth": 592,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": false,
        "skipTaskbar": true,
        "parent": "menu",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
